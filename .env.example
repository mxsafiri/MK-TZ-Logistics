# ──────────────────────────────────────────────────────────────
# Database — Neon (Postgres)
# ──────────────────────────────────────────────────────────────
# Get this from https://console.neon.tech → your project → Connection Details
# Use the POOLED connection string for the app, UNPOOLED for migrations.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# ──────────────────────────────────────────────────────────────
# Neon Auth (powered by Better Auth)
# ──────────────────────────────────────────────────────────────
# Enable Neon Auth in your Neon project: Console → Auth → Enable.
# Copy the "Auth URL" from Project Info and paste it as NEON_AUTH_BASE_URL.
# Generate a 32+ char cookie secret with: openssl rand -base64 32
NEON_AUTH_BASE_URL="https://ep-xxxx.neonauth.REGION.aws.neon.tech/neondb/auth"
NEON_AUTH_COOKIE_SECRET=""

# ──────────────────────────────────────────────────────────────
# App
# ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:6006"
NODE_ENV="development"

# ──────────────────────────────────────────────────────────────
# Sentry (optional in dev, required in prod)
# ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

# ──────────────────────────────────────────────────────────────
# FX rates (daily exchange rate sync)
# ──────────────────────────────────────────────────────────────
# Free tier: https://exchangerate.host (no key required) — leave blank to use it.
EXCHANGE_RATE_API_KEY=""
